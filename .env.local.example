# Site URL for canonical, Open Graph, and Schema (usar tu dominio en producción)
NEXT_PUBLIC_SITE_URL=https://www.rusmadrigal.com

# Sanity (optional – defaults to project 2za5lqrr, dataset production)
NEXT_PUBLIC_SANITY_PROJECT_ID=2za5lqrr
NEXT_PUBLIC_SANITY_DATASET=production

# Reports dashboard – session signing (required for /reports). Generate with: openssl rand -base64 32
REPORTS_SESSION_SECRET=

# Optional: create admin via script (node scripts/seed-admin-client.mjs prints hash for Studio)
# SANITY_API_WRITE_TOKEN=
