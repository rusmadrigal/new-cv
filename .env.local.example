# Site URL for canonical, Open Graph, and Schema (usar tu dominio en producción)
NEXT_PUBLIC_SITE_URL=https://www.rusmadrigal.com

# Sanity (optional – defaults to project 2za5lqrr, dataset production)
NEXT_PUBLIC_SANITY_PROJECT_ID=2za5lqrr
NEXT_PUBLIC_SANITY_DATASET=production

# Contact form (Resend — optional: sin RESEND_API_KEY el envío solo se registra en logs del servidor)
RESEND_API_KEY=
# Remitente verificado en Resend (ej: "Rusben <notificaciones@tudominio.com>")
RESEND_FROM=
# Destino de los leads (por defecto hello@rusmadrigal.com)
CONTACT_TO_EMAIL=hello@rusmadrigal.com

# Anti-spam (API /api/contact): en producción solo se aceptan POST con Origin/Referer del mismo sitio (NEXT_PUBLIC_SITE_URL).
# Pon true si un proxy/CDN quita el header y fallan los envíos legítimos.
# CONTACT_SKIP_ORIGIN_CHECK=false

# Opcional — Cloudflare Turnstile: verificar token en el servidor (requiere widget en el modal)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
